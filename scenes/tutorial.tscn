[node name="high jump" type="Label" parent="CanvasLayer" unique_id=297602781]
visible = false
offset_right = 40.0
offset_bottom = 23.0
text = "The basic jump height limit is 2 blocks
but with proper positioning and good timing
you can jump up 3 blocks.
Look at where the demo player is positioned 
and try it yourself!"

[node name="long jump" type="Label" parent="CanvasLayer" unique_id=1285368771]
visible = false
offset_right = 40.0
offset_bottom = 23.0
text = "When jumping from regular blocks
you can only jump 4 blocks in length
When running on ice blocks,
the additional speed allowed you to 
jump 5 blocks in length. Give it a shot!"

[node name="edge jump" type="Label" parent="CanvasLayer" unique_id=1780483976]
visible = false
offset_right = 40.0
offset_bottom = 23.0
text = "Edge jumps are tricky but totally possible
You can position yourself right on the edge
of the block and jump out to clear the ceiling.
"

